<% content_for :title, "Trocar Senha | Runvster" %>

<main class="rv-shell rv-shell--narrow">
  <%= render "shared/topbar" %>

  <section class="rv-auth">
    <article class="rv-panel">
      <p class="rv-section-eyebrow">Seguranca</p>
      <h1 class="rv-section-title rv-section-title--page">Atualize sua senha.</h1>

      <%= render "shared/form_errors", record: current_user %>

      <%= form_with model: current_user, url: account_password_path, class: "rv-form" do |form| %>
        <div class="rv-field">
          <%= label_tag "user_current_password", "Senha atual" %>
          <%= password_field_tag "user[current_password]", nil, id: "user_current_password", class: "rv-input" %>
        </div>

        <div class="rv-field">
          <%= form.label :password, "Nova senha" %>
          <%= form.password_field :password %>
        </div>

        <div class="rv-field">
          <%= form.label :password_confirmation, "Confirmar nova senha" %>
          <%= form.password_field :password_confirmation %>
        </div>

        <div class="rv-actions">
          <%= form.submit "Salvar nova senha", class: "rv-button rv-button--primary" %>
          <%= link_to "Voltar para conta", edit_account_path, class: "rv-button rv-button--secondary" %>
        </div>
      <% end %>
    </article>
  </section>
</main>
