<% content_for :title, current_user.admin? ? "Admin Dashboard | Runvster" : "Dashboard | Runvster" %>

<main class="rv-shell rv-shell--dashboard">
  <%= render "shared/topbar" %>
  <%= render "shared/section_nav",
    items: current_user.admin? ? admin_section_nav_items : member_section_nav_items,
    aria_label: current_user.admin? ? "Navegacao administrativa" : "Navegacao da conta" %>

  <% if current_user.admin? %>
    <section class="rv-dashboard rv-dashboard--admin">
      <article class="rv-dashboard-hero rv-dashboard-hero--admin">
        <div>
          <p class="rv-dashboard-eyebrow">Admin Control</p>
          <h1 class="rv-dashboard-title">Painel de operacao da comunidade</h1>
          <p class="rv-dashboard-copy">
            Centralize entrada, convites, moderacao, atividade recente e politicas da comunidade num unico lugar.
          </p>
        </div>

        <div class="rv-dashboard-badge">Convites ilimitados</div>
      </article>

      <section class="rv-dashboard-stats">
        <article class="rv-stat-card">
          <span class="rv-stat-card__label">Membros</span>
          <strong><%= @member_count %></strong>
        </article>
        <article class="rv-stat-card">
          <span class="rv-stat-card__label">Admins</span>
          <strong><%= @admin_count %></strong>
        </article>
        <article class="rv-stat-card">
          <span class="rv-stat-card__label">Posts</span>
          <strong><%= @total_posts_count %></strong>
        </article>
        <article class="rv-stat-card">
          <span class="rv-stat-card__label">Comentarios</span>
          <strong><%= @comment_count %></strong>
        </article>
        <article class="rv-stat-card">
          <span class="rv-stat-card__label">Posts ocultos</span>
          <strong><%= @hidden_posts_count %></strong>
        </article>
        <article class="rv-stat-card">
          <span class="rv-stat-card__label">Comentarios ocultos</span>
          <strong><%= @hidden_comments_count %></strong>
        </article>
      </section>

      <section class="rv-dashboard-grid">
        <article class="rv-panel rv-dashboard-panel rv-dashboard-panel--admin-accent">
          <p class="rv-section-eyebrow">Convidar</p>
          <h2 class="rv-card-title">Abrir novas vagas</h2>
          <p class="rv-meta">O admin pode enviar convites sem limite e ajustar as politicas no painel de convites.</p>

          <%= form_with model: Invitation.new, url: invitations_path, class: "rv-form rv-form--inline" do |form| %>
            <div class="rv-field">
              <%= form.label :recipient_email, "Email do convite" %>
              <%= form.email_field :recipient_email, placeholder: "nova-pessoa@dominio.com" %>
            </div>

            <div class="rv-actions">
              <%= form.submit "Enviar convite", class: "rv-button rv-button--primary" %>
            </div>
          <% end %>
        </article>

        <%= render "shared/api_tokens_panel",
          api_tokens: @api_tokens,
          fresh_api_token: @fresh_api_token,
          title: "Tokens para integracoes e dashboards",
          description: "Gere um bearer token pessoal para consumir a API sem depender da sessao web." %>

        <%= render "shared/weekly_digest_panel", summary: @weekly_digest_summary %>

        <article class="rv-panel rv-dashboard-panel">
          <p class="rv-section-eyebrow">Entrada recente</p>
          <h2 class="rv-card-title">Ultimos usuarios</h2>

          <% if @latest_members.any? %>
            <ul class="rv-dashboard-list">
              <% @latest_members.each do |user| %>
                <li>
                  <strong><%= link_to "@#{user.username}", user_path(user), class: "rv-inline-link" %></strong>
                  <span><%= user.role %> · <%= user.account_state %> · <%= time_ago_in_words(user.created_at) %> atras</span>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="rv-meta">Nenhum outro usuario entrou ainda.</p>
          <% end %>
        </article>

        <article class="rv-panel rv-dashboard-panel">
          <p class="rv-section-eyebrow">Fila de convites</p>
          <h2 class="rv-card-title">Estado dos convites</h2>

          <% if @recent_invitations.any? %>
            <ul class="rv-dashboard-list">
              <% @recent_invitations.each do |invitation| %>
                <li>
                  <strong><%= invitation.recipient_email %></strong>
                  <span>
                    por @<%= invitation.inviter.username %>
                    · <%= invitation.accepted? ? "aceito" : invitation.active? ? "pendente" : invitation.revoked? ? "revogado" : "expirado" %>
                  </span>
                  <% if invitation.active? %>
                    <input class="rv-input rv-input--compact" value="<%= invitation_signup_url(invitation) %>" readonly>
                  <% end %>
                </li>
              <% end %>
            </ul>
            <div class="rv-actions">
              <%= link_to "Abrir painel de convites", admin_invitations_path, class: "rv-button rv-button--secondary rv-button--tiny" %>
            </div>
          <% else %>
            <p class="rv-meta">Nenhum convite emitido ate agora.</p>
          <% end %>
        </article>

        <article class="rv-panel rv-dashboard-panel">
          <p class="rv-section-eyebrow">Moderacao</p>
          <h2 class="rv-card-title">Fila operacional</h2>

          <% if @moderation_cases.any? %>
            <ul class="rv-dashboard-list">
              <% @moderation_cases.each do |moderation_case| %>
                <li>
                  <strong><%= moderation_case.reason %></strong>
                  <span><%= moderation_case.reportable_type %> · <%= moderation_case.status %></span>
                </li>
              <% end %>
            </ul>
            <div class="rv-actions">
              <%= link_to "Abrir fila de moderacao", admin_moderation_cases_path, class: "rv-button rv-button--secondary rv-button--tiny" %>
            </div>
          <% else %>
            <p class="rv-meta">Nenhum caso novo para moderar.</p>
          <% end %>
        </article>

        <article class="rv-panel rv-dashboard-panel">
          <p class="rv-section-eyebrow">Atividade</p>
          <h2 class="rv-card-title">Posts recentes da plataforma</h2>

          <% if @recent_platform_posts.any? %>
            <ul class="rv-dashboard-list">
              <% @recent_platform_posts.each do |post| %>
                <li>
                  <strong><%= link_to post.title, post_path(post), class: "rv-inline-link" %></strong>
                  <span>por @<%= post.user.username %> · score <%= post.score %></span>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="rv-meta">A comunidade ainda nao publicou posts.</p>
          <% end %>
        </article>

        <article class="rv-panel rv-dashboard-panel">
          <p class="rv-section-eyebrow">Acoes de admin</p>
          <h2 class="rv-card-title">Historico administrativo</h2>

          <% if @admin_actions.any? %>
            <ul class="rv-dashboard-list">
              <% @admin_actions.each do |action| %>
                <li>
                  <strong><%= action.action_type.humanize %></strong>
                  <span><%= action.details %></span>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="rv-meta">Nenhuma acao administrativa registrada.</p>
          <% end %>

          <div class="rv-actions">
            <%= link_to "Gerir usuarios", admin_users_path, class: "rv-button rv-button--secondary rv-button--tiny" %>
            <%= link_to "Gerir posts", admin_posts_path, class: "rv-button rv-button--secondary rv-button--tiny" %>
            <%= link_to "Gerir comentarios", admin_comments_path, class: "rv-button rv-button--secondary rv-button--tiny" %>
            <%= link_to "Gerir convites", admin_invitations_path, class: "rv-button rv-button--secondary rv-button--tiny" %>
            <%= link_to "Editar tags", admin_tags_path, class: "rv-button rv-button--ghost rv-button--tiny" %>
          </div>
        </article>
      </section>
    </section>
  <% else %>
    <section class="rv-dashboard rv-dashboard--member">
      <article class="rv-dashboard-hero rv-dashboard-hero--member">
        <div>
          <p class="rv-dashboard-eyebrow"><%= current_user.staff? ? "Moderator Space" : "Member Space" %></p>
          <h1 class="rv-dashboard-title"><%= current_user.staff? ? "Seu painel de moderacao e participacao" : "Seu painel de participacao" %></h1>
          <p class="rv-dashboard-copy">
            Acompanhe posts, convites, inbox, confirmacao de email e o estado atual da sua participacao na comunidade.
          </p>
        </div>

        <div class="rv-dashboard-badge">
          <% if current_user.invite_eligible? %>
            <%= current_user.available_invites_count %> convites disponiveis
          <% else %>
            convites bloqueados por maturacao
          <% end %>
        </div>
      </article>

      <div class="rv-banner <%= current_user.email_verified? ? "rv-banner--success" : "rv-banner--warning" %>">
        <div>
          <strong><%= current_user.email_verified? ? "Email confirmado" : "Email pendente de confirmacao" %></strong>
          <p class="rv-meta">
            <% if current_user.email_verified? %>
              Seu email esta pronto para resumos, recuperacao de senha e fluxos de convite.
            <% else %>
              Confirme seu email para fortalecer a conta e destravar fluxos por email.
            <% end %>
          </p>
        </div>

        <% unless current_user.email_verified? %>
          <%= button_to "Reenviar confirmacao", email_confirmation_path, method: :post, class: "rv-button rv-button--secondary rv-button--tiny" %>
        <% end %>
      </div>

      <section class="rv-dashboard-stats">
        <article class="rv-stat-card">
          <span class="rv-stat-card__label">Posts publicados</span>
          <strong><%= current_user.posts_count %></strong>
        </article>
        <article class="rv-stat-card">
          <span class="rv-stat-card__label">Convites usados</span>
          <strong><%= current_user.invites_used_count %></strong>
        </article>
        <article class="rv-stat-card">
          <span class="rv-stat-card__label">Convites pendentes</span>
          <strong><%= @pending_invitations_count %></strong>
        </article>
        <article class="rv-stat-card">
          <span class="rv-stat-card__label">Reportes abertos</span>
          <strong><%= @open_reports_count %></strong>
        </article>
        <article class="rv-stat-card">
          <span class="rv-stat-card__label">Perfil</span>
          <strong><%= link_to "@#{current_user.username}", user_path(current_user), class: "rv-inline-link" %></strong>
        </article>
      </section>

      <section class="rv-dashboard-grid">
        <% if current_user.staff? %>
          <article class="rv-panel rv-dashboard-panel rv-panel--attention">
            <p class="rv-section-eyebrow">Moderacao</p>
            <h2 class="rv-card-title">Ferramentas de staff ativas</h2>
            <p class="rv-meta">
              Ha <strong><%= ModerationCase.open.count %></strong> casos abertos, <strong><%= @hidden_posts_count %></strong> posts ocultos
              e <strong><%= @hidden_comments_count %></strong> comentarios ocultos.
            </p>
            <div class="rv-actions">
              <%= link_to "Abrir fila de moderacao", admin_moderation_cases_path, class: "rv-button rv-button--primary rv-button--tiny" %>
              <%= link_to "Revisar usuarios", admin_users_path, class: "rv-button rv-button--secondary rv-button--tiny" %>
            </div>
          </article>
        <% end %>

        <article class="rv-panel rv-dashboard-panel rv-dashboard-panel--member-accent">
          <p class="rv-section-eyebrow">Convites</p>
          <h2 class="rv-card-title">Convide gente boa quando seu acesso amadurecer</h2>

          <% if current_user.can_send_invite? %>
            <p class="rv-meta">
              Sua cota total e de <strong><%= current_user.invite_limit %> convites</strong>.
              Restam <strong><%= current_user.available_invites_count %></strong>.
            </p>

            <%= form_with model: Invitation.new, url: invitations_path, class: "rv-form rv-form--inline" do |form| %>
              <div class="rv-field">
                <%= form.label :recipient_email, "Email da pessoa convidada" %>
                <%= form.email_field :recipient_email, placeholder: "pessoa@dominio.com" %>
              </div>

              <div class="rv-actions">
                <%= form.submit "Enviar convite", class: "rv-button rv-button--primary" %>
              </div>
            <% end %>
          <% elsif current_user.invite_eligible? %>
            <p class="rv-meta">
              Sua cota de convites ja foi totalmente usada. O admin pode ajustar essa politica quando abrir uma nova leva.
            </p>
          <% else %>
            <p class="rv-meta">
              Seus convites liberam depois de <strong><%= CommunitySetting.current.member_invite_unlock_days %> dias de uso</strong>.
              Abertura prevista: <strong><%= l(current_user.invite_unlocks_at, format: :long) %></strong>.
            </p>
          <% end %>
        </article>

        <%= render "shared/api_tokens_panel",
          api_tokens: @api_tokens,
          fresh_api_token: @fresh_api_token,
          title: "Tokens para usar a API",
          description: "Crie um token pessoal para scripts, automacoes e dashboards externas falarem com /api/v1." %>

        <%= render "shared/weekly_digest_panel", summary: @weekly_digest_summary %>

        <article class="rv-panel rv-dashboard-panel">
          <p class="rv-section-eyebrow">Seu backlog</p>
          <h2 class="rv-card-title">Posts recentes</h2>

          <% if @recent_posts.any? %>
            <ul class="rv-dashboard-list">
              <% @recent_posts.each do |post| %>
                <li>
                  <strong><%= link_to post.title, post_path(post), class: "rv-inline-link" %></strong>
                  <span><%= time_ago_in_words(post.created_at) %> atras</span>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="rv-meta">Voce ainda nao publicou nada. Seu primeiro post pode ajudar a definir o tom do espaco.</p>
          <% end %>
        </article>

        <article class="rv-panel rv-dashboard-panel">
          <p class="rv-section-eyebrow">Historico</p>
          <h2 class="rv-card-title">Convites enviados</h2>

          <% if @recent_invitations.any? %>
            <ul class="rv-dashboard-list">
              <% @recent_invitations.each do |invitation| %>
                <li>
                  <strong><%= invitation.recipient_email %></strong>
                  <span><%= invitation.accepted? ? "aceito" : invitation.active? ? "pendente" : invitation.revoked? ? "revogado" : "expirado" %></span>
                  <% if invitation.active? %>
                    <input class="rv-input rv-input--compact" value="<%= invitation_signup_url(invitation) %>" readonly>
                  <% end %>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="rv-meta">Nenhum convite enviado ate agora.</p>
          <% end %>
        </article>

        <article class="rv-panel rv-dashboard-panel">
          <p class="rv-section-eyebrow">Inbox</p>
          <h2 class="rv-card-title">Notificacoes recentes</h2>

          <% if @notifications.any? %>
            <ul class="rv-dashboard-list">
              <% @notifications.each do |notification| %>
                <li>
                  <strong><%= notification.message %></strong>
                  <span><%= time_ago_in_words(notification.created_at) %> atras</span>
                </li>
              <% end %>
            </ul>
            <div class="rv-actions">
              <%= link_to "Abrir inbox", notifications_path, class: "rv-button rv-button--secondary rv-button--tiny" %>
            </div>
          <% else %>
            <p class="rv-meta">Seu inbox ainda esta vazio.</p>
          <% end %>
        </article>
      </section>
    </section>
  <% end %>
</main>
