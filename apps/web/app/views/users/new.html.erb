<% content_for :title, "Criar Conta | Runvster" %>

<main class="rv-shell rv-shell--narrow">
  <%= render "shared/topbar" %>

  <section class="rv-auth">
    <article class="rv-panel">
      <p class="rv-eyebrow">Onboarding</p>
      <h1 class="rv-section-title rv-section-title--page">
        <%= User.count.zero? ? "Abra a primeira camada da comunidade." : "Ative seu convite e entre na comunidade." %>
      </h1>
      <p class="rv-lead rv-lead--compact">
        <% if User.count.zero? %>
          Esse fluxo cria o primeiro usuario administrador e abre a operacao inicial da plataforma.
        <% else %>
          Esse fluxo valida seu convite, cria a conta, inicia a sessao e te leva direto para sua dashboard. Em seguida, voce recebe um email para confirmar o acesso.
        <% end %>
      </p>

      <% if @invitation.present? %>
        <p class="rv-meta">Convite para <strong><%= @invitation.recipient_email %></strong> valido ate <%= l(@invitation.expires_at, format: :long) %>.</p>
      <% end %>

      <%= render "shared/form_errors", record: @user %>

      <%= form_with model: @user, url: users_path(invite: @invitation&.token), class: "rv-form" do |form| %>
        <div class="rv-field">
          <%= form.label :username, "Username" %>
          <%= form.text_field :username, autofocus: true, placeholder: "runvster" %>
        </div>

        <div class="rv-field">
          <%= form.label :email, "Email" %>
          <%= form.email_field :email, placeholder: "voce@runv.club", value: @invitation&.recipient_email, readonly: @invitation.present? %>
        </div>

        <div class="rv-field">
          <%= form.label :bio, "Bio curta" %>
          <%= form.text_area :bio, rows: 4, placeholder: "O que voce constroi, opera ou pesquisa?" %>
        </div>

        <div class="rv-field">
          <%= form.label :password, "Senha" %>
          <%= form.password_field :password, placeholder: "Minimo de 8 caracteres" %>
        </div>

        <div class="rv-field">
          <%= form.label :password_confirmation, "Confirmar senha" %>
          <%= form.password_field :password_confirmation, placeholder: "Repita a senha" %>
        </div>

        <div class="rv-actions">
          <%= form.submit "Criar conta", class: "rv-button rv-button--primary" %>
        </div>
      <% end %>
    </article>
  </section>
</main>
