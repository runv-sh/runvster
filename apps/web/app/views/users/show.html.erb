<% content_for :title, "@#{@user.username} | Runvster" %>

<main class="rv-shell">
  <%= render "shared/topbar" %>

  <section class="rv-layout">
    <div class="rv-column rv-column--main">
      <article class="rv-panel">
        <p class="rv-section-eyebrow">Perfil</p>
        <h1 class="rv-section-title rv-section-title--page">@<%= @user.username %></h1>
        <p class="rv-lead rv-lead--compact"><%= @user.bio.presence || "Ainda sem bio publicada." %></p>
        <% if authenticated? && current_user == @user %>
          <div class="rv-actions">
            <%= link_to "Editar conta", edit_account_path, class: "rv-button rv-button--secondary rv-button--tiny" %>
          </div>
        <% end %>
        <% if authenticated? && current_user != @user %>
          <%= render "shared/moderation_form", reportable: @user %>
        <% end %>
      </article>

      <div class="rv-section-head rv-section-head--compact">
        <div>
          <p class="rv-section-eyebrow">Posts</p>
          <h2 class="rv-section-title">Publicados por @<%= @user.username %></h2>
        </div>
      </div>

      <% if @posts.any? %>
        <section class="rv-feed-stream rv-feed-stream--flat rv-feed-stream--embedded">
          <ol class="rv-feed-list">
            <% @posts.each_with_index do |post, index| %>
              <%= render "posts/post_card", post: post, index: index %>
            <% end %>
          </ol>
        </section>
      <% else %>
        <article class="rv-empty">
          <h3>Nenhum post ainda.</h3>
          <p>Esse perfil ainda nao publicou nada no alpha.</p>
        </article>
      <% end %>
    </div>

    <aside class="rv-column rv-column--side">
      <article class="rv-panel">
        <p class="rv-section-eyebrow">Resumo</p>
        <p class="rv-meta"><%= pluralize(@user.posts_count, "post") %> publicados ate agora.</p>
        <p class="rv-meta"><%= @user.email_verified? ? "email confirmado" : "email pendente" %></p>
      </article>
    </aside>
  </section>
</main>
