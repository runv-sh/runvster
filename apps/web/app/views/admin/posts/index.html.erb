<% content_for :title, "Admin Posts | Runvster" %>

<main class="rv-shell">
  <%= render "shared/topbar" %>

  <section class="rv-stack">
    <article class="rv-panel">
      <p class="rv-section-eyebrow">Admin</p>
      <h1 class="rv-section-title rv-section-title--page">Gestao de posts</h1>

      <div class="rv-admin-table">
        <% @posts.each do |post| %>
          <div class="rv-admin-table__row rv-admin-table__row--stacked">
            <div>
              <strong><%= link_to post.title, post_path(post), class: "rv-inline-link" %></strong>
              <p class="rv-meta">por @<%= post.user.username %> · score <%= post.score %> · <%= pluralize(post.comments_count, "comentario") %></p>
            </div>

            <%= form_with model: [ :admin, post ], class: "rv-form" do |form| %>
              <div class="rv-field">
                <%= form.label :title, "Titulo" %>
                <%= form.text_field :title %>
              </div>
              <div class="rv-field">
                <%= form.label :url, "Link" %>
                <%= form.url_field :url %>
              </div>
              <div class="rv-field">
                <%= form.label :body, "Contexto" %>
                <%= form.text_area :body, rows: 4 %>
              </div>
              <div class="rv-field">
                <%= label_tag "post_#{post.id}_tag_names", "Tags" %>
                <%= text_field_tag "post[tag_names]", post.tag_list, id: "post_#{post.id}_tag_names", class: "rv-input" %>
              </div>
              <div class="rv-actions">
                <%= form.submit "Salvar post", class: "rv-button rv-button--primary rv-button--tiny" %>
              </div>
            <% end %>

            <div class="rv-actions">
              <%= button_to "Excluir post", admin_post_path(post), method: :delete, class: "rv-button rv-button--ghost rv-button--tiny", form: { data: { turbo_confirm: "Excluir este post?" } } %>
            </div>
          </div>
        <% end %>
      </div>
    </article>
  </section>
</main>
